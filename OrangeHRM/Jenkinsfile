pipeline {
    agent any

    triggers {
        pollSCM('* * * * *')
    }

    tools {
        maven 'Maven3'
        jdk 'Java21'
    }

    stages {
        stage('Build') {
            steps {
                dir('OrangeHRM') {
                    bat 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('OrangeHRM') {
                    bat 'mvn test'
                }
            }
        }

        stage('Report') {
            steps {
                echo 'Reports generated in OrangeHRM/test-output'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'OrangeHRM/ScreenShots/*.png',
                             fingerprint: true,
                             allowEmptyArchive: true
        }
        success {
            echo 'Build Passed ✅'
        }
        failure {
            echo 'Build Failed ❌'
        }
    }
}