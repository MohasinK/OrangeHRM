pipeline {
    agent any
    
     triggers {
        githubPush()
    }

    tools {
        maven 'Maven1'
        jdk 'jdk21'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/MohasinK/OrangeHRM.git'
            }
        }

        stage('Run Tests') {
            steps {
                dir('OrangeHRM') {
                    bat 'mvn clean test -Dchrome.headless=true'
                }
            }
        }

        stage('Publish Report') {
            steps {
                publishHTML(target: [
                    allowMissing: true,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'OrangeHRM/Reports',
                    reportFiles: 'OrangeHRM_ExtentReport.html',
                    reportName: 'Extent Report'
                ])
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'OrangeHRM/ScreenShots/*.png',
                             allowEmptyArchive: true
        }

        success {
            echo 'Build Passed ✅'
        }

        failure {
            echo 'Build Failed ❌'
        }
    }
}